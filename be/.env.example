# Copy this file to be/.env and fill real values there.
# Never commit be/.env because it contains backend secrets.

# Backend port used by npm run server.
PORT=8787

# Privy backend credentials from https://dashboard.privy.io
# PRIVY_APP_ID is public-ish, but keep one source of truth here for backend.
# PRIVY_APP_SECRET is private and must stay on the server only.
PRIVY_APP_ID=your_privy_app_id
PRIVY_APP_SECRET=your_privy_app_secret

# Stellar Horizon APIs.
# Keep both networks so the app can switch Testnet <-> Mainnet.
HORIZON_TESTNET_URL=https://horizon-testnet.stellar.org
HORIZON_MAINNET_URL=https://horizon.stellar.org

# Friendbot only exists for Stellar Testnet. Mainnet must be funded with real XLM.
FRIENDBOT_URL=https://friendbot.stellar.org

# Optional: only needed if WalletConnect/Reown flows are enabled.
WALLETCONNECT_PROJECT_ID=

# Storage.
# Use DB_DRIVER=json for quick local demos, mysql for staging/production.
DB_DRIVER=mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=stellar
MYSQL_USER=root
MYSQL_PASSWORD=
