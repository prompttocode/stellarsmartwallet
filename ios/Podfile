# Resolve native Pod scripts with node to allow for hoisting.
require 'json'
require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'Privy' do
  use_expo_modules!

  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Fix: fmt consteval errors with Xcode 16+/26 toolchain.
    installer.pods_project.targets.each do |target|
      if target.name == 'fmt'
        target.build_configurations.each do |config|
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'FMT_USE_CONSTEVAL=0'
        end
      end
    end

    # fmt's base.h hard-defines FMT_USE_CONSTEVAL without a guard, so allow the
    # build setting above to take effect while keeping fmt's companion macros.
    fmt_base = File.join(installer.sandbox.pod_dir('fmt'), 'include/fmt/base.h')
    if File.exist?(fmt_base)
      contents = File.read(fmt_base)
      marker = '// PRIVY-PATCH: allow Pod build setting to force consteval off.'
      unless contents.include?(marker)
        broken_patch = <<~FMT
          // PRIVY-PATCH: force FMT_USE_CONSTEVAL=0
          #define FMT_USE_CONSTEVAL 0
        FMT

        restored_block = <<~FMT
          // Detect consteval, C++20 constexpr extensions and std::is_constant_evaluated.
          #ifdef FMT_USE_CONSTEVAL
          #{marker}
          #elif !defined(__cpp_lib_is_constant_evaluated)
          #  define FMT_USE_CONSTEVAL 0
          #elif FMT_CPLUSPLUS < 201709L
          #  define FMT_USE_CONSTEVAL 0
          #elif FMT_GLIBCXX_RELEASE && FMT_GLIBCXX_RELEASE < 10
          #  define FMT_USE_CONSTEVAL 0
          #elif FMT_LIBCPP_VERSION && FMT_LIBCPP_VERSION < 10000
          #  define FMT_USE_CONSTEVAL 0
          #elif defined(__apple_build_version__) && __apple_build_version__ < 14000029L
          #  define FMT_USE_CONSTEVAL 0  // consteval is broken in Apple clang < 14.
          #elif FMT_MSC_VERSION && FMT_MSC_VERSION < 1929
          #  define FMT_USE_CONSTEVAL 0  // consteval is broken in MSVC VS2019 < 16.10.
          #elif defined(__cpp_consteval)
          #  define FMT_USE_CONSTEVAL 1
          #elif FMT_GCC_VERSION >= 1002 || FMT_CLANG_VERSION >= 1101
          #  define FMT_USE_CONSTEVAL 1
          #else
          #  define FMT_USE_CONSTEVAL 0
          #endif
          #if FMT_USE_CONSTEVAL
          #  define FMT_CONSTEVAL consteval
          #  define FMT_CONSTEXPR20 constexpr
          #else
          #  define FMT_CONSTEVAL
          #  define FMT_CONSTEXPR20
          #endif
        FMT

        patched = contents.sub(broken_patch, restored_block)
        if patched == contents
          patched = contents.sub(
            "// Detect consteval, C++20 constexpr extensions and std::is_constant_evaluated.\n#if !defined(__cpp_lib_is_constant_evaluated)",
            "// Detect consteval, C++20 constexpr extensions and std::is_constant_evaluated.\n#ifdef FMT_USE_CONSTEVAL\n#{marker}\n#elif !defined(__cpp_lib_is_constant_evaluated)"
          )
        end

        File.write(fmt_base, patched)
      end
    end

    # Expo 55 references RCTDevMenuConfiguration, which is only available in
    # React Native 0.83+. Keep RN 0.82 on the older root view factory API.
    rn_package_path = File.expand_path('../node_modules/react-native/package.json', Pod::Config.instance.installation_root)
    rn_minor = File.exist?(rn_package_path) ? JSON.parse(File.read(rn_package_path))['version'].split('.')[1].to_i : 0

    if rn_minor < 83
      expo_root = File.expand_path('../node_modules/expo', Pod::Config.instance.installation_root)
      [
        File.join(expo_root, 'ios/AppDelegates/EXReactRootViewFactory.h'),
        File.join(expo_root, 'ios/AppDelegates/EXReactRootViewFactory.mm')
      ].each do |file|
        next unless File.exist?(file)

        contents = File.read(file)
        patched = contents.gsub(
          '#if TARGET_OS_IOS || TARGET_OS_TV',
          '#if (TARGET_OS_IOS || TARGET_OS_TV) && REACT_NATIVE_TARGET_VERSION >= 83'
        )
        File.write(file, patched) if patched != contents
      end

      expo_factory = File.join(expo_root, 'ios/AppDelegates/ExpoReactNativeFactory.swift')
      if File.exist?(expo_factory)
        contents = File.read(expo_factory)
        patched = contents.gsub(
          '#if os(iOS) || os(tvOS)',
          '#if EXPO_RN_83_ROOT_VIEW_FACTORY && (os(iOS) || os(tvOS))'
        )
        File.write(expo_factory, patched) if patched != contents
      end
    end
  end
end
